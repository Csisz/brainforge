# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers (only the ones you enable; see src/lib/ai/provider.ts)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google login button (0 = hidden; set to 1 only after configuring
# [auth.external.google] in supabase/config.toml — see comments there)
NEXT_PUBLIC_AUTH_GOOGLE=0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
