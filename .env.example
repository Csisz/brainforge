# ─────────────────────────────────────────────────────────────────────────
# REQUIRED — the app validates these at boot (src/lib/env.ts) and fails fast
# with a readable message if any are missing or malformed.
# ─────────────────────────────────────────────────────────────────────────

# Supabase. Local: the values printed by `supabase start`. Production: the
# Project URL + anon key + service-role key from Supabase Cloud → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the app. Local: http://localhost:3000. Production: your
# real domain, e.g. https://kalmokids.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL — features degrade gracefully when unset (billing hidden, email
# skipped, Google button hidden). Stripe is validated all-or-nothing.
# ─────────────────────────────────────────────────────────────────────────

# Stripe (billing). Empty ⇒ billing UI hidden. Set ALL four together.
# Prices are the test/live price ids of the €9 Premium and €14 Family products.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_FAMILY=

# Transactional email (Resend). Empty ⇒ app-sent email silently skipped.
# Auth emails (magic links) are separate — Supabase SMTP, see config.toml / README.
RESEND_API_KEY=
EMAIL_FROM="Kalmo Kids <hello@kalmokids.com>"

# AI providers — decorative language only (see src/lib/ai/provider.ts). Optional;
# the product works fully with AI disabled.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Google login button (0 = hidden; set to 1 only after configuring
# [auth.external.google] in supabase/config.toml — see comments there)
NEXT_PUBLIC_AUTH_GOOGLE=0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
