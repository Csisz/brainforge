# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers (only the ones you enable; see src/lib/ai/provider.ts)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google login button (0 = hidden; set to 1 only after configuring
# [auth.external.google] in supabase/config.toml — see comments there)
NEXT_PUBLIC_AUTH_GOOGLE=0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (billing). Leave empty to hide billing UI in local dev.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_FAMILY=

# Transactional email (Resend). Leave empty to skip app-sent email (silent).
# Auth emails (magic links) are separate — configured in Supabase SMTP settings.
RESEND_API_KEY=
EMAIL_FROM="BrainForge Kids <onboarding@resend.dev>"
